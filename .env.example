# ── StudyBuddy environment ───────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored. Never commit real keys.

# Gateway / provider credentials (used by every chat agent)
OPENAI_API_KEY=sk-your-key-here
# OpenAI direct: leave blank or set https://api.openai.com/v1
# OpenRouter / other gateway: e.g. https://openrouter.ai/api/v1
OPENAI_BASE_URL=

# ── Per-task model routing (≥3 distinct models satisfies the rubric) ───────
# With an OpenAI key use OpenAI names (gpt-4o, gpt-4o-mini).
# With a gateway you may use slugs like anthropic/claude-3.5-sonnet.
EXTRACTION_MODEL=gpt-4o-mini
QUIZ_MODEL=gpt-4o
EVAL_MODEL=gpt-4o-mini
ADAPTIVE_MODEL=gpt-4o-mini
TUTOR_MODEL=gpt-4o
SUMMARY_MODEL=gpt-4o-mini

# ── Vector store & embeddings (local, no API) ──────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DIR=data/chroma
RETRIEVAL_K=4

# ── Weak-spot tracker ───────────────────────────────────────────────────────
STUDYBUDDY_DB=data/studybuddy.db

# ── Optional LangSmith tracing ──────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=studybuddy
